{
  "name": "i18n-dashboard",

  "version": "0.13.3",
  "description": "A web dashboard to manage vue-i18n translation keys with database persistence",
  "type": "module",
  "bin": {
    "i18n-dashboard": "./bin/cli.mjs"
  },
  "scripts": {
    "dev": "nuxt dev --port 3333",
    "build": "nuxt build",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "start": "node bin/cli.mjs start",
    "start:detach": "node bin/cli.mjs start --detach",
    "stop": "node bin/cli.mjs stop",
    "init": "node bin/cli.mjs init",
    "sync": "node bin/cli.mjs sync",
    "cy:open": "cypress open",
    "cy:run": "cypress run",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@nuxt/ui": "^3.3.7",
    "@vitalets/google-translate-api": "^9.2.1",
    "bcryptjs": "^2.4.3",
    "commander": "^13.1.0",
    "knex": "^3.1.0",
    "nodemailer": "^6.10.1",
    "nuxt": "^3.21.1",
    "vue": "^3.5.13"
  },
  "optionalDependencies": {
    "better-sqlite3": "^11.8.1",
    "mysql2": "^3.13.0",
    "pg": "^8.14.0"
  },
  "peerDependencies": {
    "vue-i18n": ">=9.0.0"
  },
  "peerDependenciesMeta": {
    "vue-i18n": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "src/",
    "bin/",
    "nuxt.config.ts",
    "tsconfig.json",
    "i18n-dashboard.config.example.js"
  ],
  "author": "i18n-dashboard contributors",
  "repository": {
    "type": "git",
    "url": "https://github.com/arnaudprioul/i18n-dashboard.git"
  },
  "homepage": "https://github.com/arnaudprioul/i18n-dashboard#readme",
  "bugs": {
    "url": "https://github.com/arnaudprioul/i18n-dashboard/issues"
  },
  "keywords": [
    "vue",
    "vue-i18n",
    "i18n",
    "translations",
    "dashboard",
    "localization"
  ],
  "license": "MIT",
  "devDependencies": {
    "@iconify-json/heroicons": "^1.2.3",
    "@types/node": "^25.3.5",
    "@vitest/coverage-v8": "^4.1.0",
    "@vitest/ui": "^4.1.0",
    "@vue/test-utils": "^2.4.6",
    "cypress": "^15.12.0",
    "happy-dom": "^20.8.4",
    "vitest": "^4.1.0"
  }
}
